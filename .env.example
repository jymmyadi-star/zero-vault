# Mobile app (Expo) — client-side env vars (EXPO_PUBLIC_ prefix required)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_ZEROVAULT_API_URL=http://localhost:4000

# Server-side env vars
SUPABASE_URL=
SUPABASE_ANON_KEY=
ZEROVAULT_API_URL=http://localhost:4000

# Redis (required for multi-instance rate limiting)
# In Docker Compose: automatically set to redis://redis:6379
# For local dev without Docker: redis://localhost:6379
REDIS_URL=redis://localhost:6379
