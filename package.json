{
  "name": "zero-vault",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 npx expo start",
    "dev:tunnel": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 npx expo start --tunnel",
    "dev:web": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 npx expo start --web --port 8081",
    "server": "cross-env NODE_ENV=development tsx server/index.ts",
    "server:dev": "tsx server/dev.ts",
    "server:prod": "cross-env NODE_ENV=production node dist/server/index.js",
    "build:server": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/server/index.js",
    "check": "tsc --noEmit",
    "check:server": "tsc --noEmit -p server/tsconfig.json",
    "lint": "expo lint",
    "format": "prettier --write .",
    "test": "vitest run",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@morrowdigital/watermelondb-expo-plugin": "^2.3.3",
    "@noble/ciphers": "2.2.0",
    "@noble/hashes": "2.2.0",
    "@nozbe/watermelondb": "^0.28.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.9.2",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "2.104.1",
    "@trpc/client": "^11.17.0",
    "@trpc/server": "^10.45.0",
    "@types/react": "~19.2.10",
    "argon2": "^0.44.0",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "eslint-config-expo": "~55.0.1",
    "expo": "^55.0.23",
    "expo-blur": "~55.0.14",
    "expo-build-properties": "~55.0.0",
    "expo-clipboard": "~55.0.0",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "~55.0.32",
    "expo-file-system": "~55.0.19",
    "expo-font": "~55.0.7",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.10",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.15",
    "expo-local-authentication": "~55.0.13",
    "expo-router": "~55.0.14",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.0",
    "expo-status-bar": "~55.0.6",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "fast-json-stable-stringify": "^2.1.0",
    "helmet": "^8.1.0",
    "nativewind": "^4.2.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-css-interop": "^0.2.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-quick-crypto": "^1.1.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.4",
    "tailwind-merge": "^2.6.0",
    "ws": "^8.20.1",
    "zod": "^4.2.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.3",
    "@types/react": "~19.2.10",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~55.0.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.7.4",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "@types/react": "$@types/react"
  }
}
